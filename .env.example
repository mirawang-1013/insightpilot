# ============================================================================
# .env.example —— 环境变量样例
#
# 用法：复制为 .env 并填入真实值
#   cp .env.example .env
#
# 【为什么是 .env.example 而不是 .env？】
#   .env 里有密钥，必须 gitignore；.env.example 无敏感值，可以入库，
#   让别人 clone 下来知道"我需要填哪些变量"。这是 12-Factor App 的标准做法。
# ============================================================================

# ---- OpenAI API ----
# 必填。从 https://platform.openai.com/api-keys 获取
OPENAI_API_KEY=sk-proj
# 使用的模型（默认 gpt-4o；预算有限可换 gpt-4o-mini 做开发）
OPENAI_MODEL=gpt-4o

# ---- 数据层 ----
# DuckDB 数据库文件路径（默认项目内 data/warehouse.duckdb）
DUCKDB_PATH=data/warehouse.duckdb

# SQL 查询结果行数上限（防止 Agent 拉全表爆内存）
MAX_SQL_ROWS=500

# SQL 执行超时（秒）
SQL_TIMEOUT=30

# ---- Python 沙盒（第三阶段用）----
# Analysis Agent subprocess 执行的超时时间
PYTHON_SANDBOX_TIMEOUT=60

# ---- LangGraph 循环保护 ----
# 单次图执行的最大循环次数（防止 ReAct 死循环）
MAX_ITERATIONS=20

# ---- 日志 ----
LOG_LEVEL=INFO
